{
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "printWidth": 80,
  "xmlWhitespaceSensitivity": "strict",
  "xmlSortAttributes": false,
  {
    "overrides":
      [
        { "files": "*.js", "options": { "tabWidth": 4 } },
        { "files": "*.ts", "options": { "tabWidth": 4 } },
      ],
  },
}
